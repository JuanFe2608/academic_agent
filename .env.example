# ============================================================
# Lara Academic Agent — Variables de entorno requeridas
# Copia este archivo como .env y rellena los valores
# ============================================================

# ------------------------------------------------------------
# Azure OpenAI (LLM + Embeddings)
# ------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://TU_RECURSO.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_NAME_EMBEDDINGS=embeddings-3-small
OPENAI_API_VERSION=2024-12-01-preview

# Azure OpenAI audio transcription. Debe usar endpoint base, no URL de /audio/transcriptions.
AZURE_OPENAI_API_KEY_TRANSCRIBE=
AZURE_OPENAI_ENDPOINT_TRANSCRIBE=https://TU_RECURSO.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME_TRANSCRIBE=gpt-4o-mini-transcribe
OPENAI_API_VERSION_TRANSCRIBE=2025-03-01-preview

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
PGHOST=
PGPORT=5432
PGDATABASE=academic_agent
PGUSER=
PGPASSWORD=
# Alternativa: URL completa (sobreescribe los campos anteriores)
# ACADEMIC_AGENT_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Checkpointer (por defecto usa la misma base de datos)
# LANGGRAPH_CHECKPOINTER_DATABASE_URL=

# ------------------------------------------------------------
# WhatsApp Cloud API
# ------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
# Token aleatorio que configuraste en Meta Developer Portal
WHATSAPP_VERIFY_TOKEN=
# App Secret de Meta Developers → App Settings → Basic → App Secret
# Requerido para validar la firma X-Hub-Signature-256 del webhook POST
WHATSAPP_APP_SECRET=

# ------------------------------------------------------------
# Microsoft Graph (OAuth + Outlook)
# ------------------------------------------------------------
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
# URL publica de tu despliegue + /oauth/callback
MICROSOFT_REDIRECT_URI=https://TU_DOMINIO.azurecontainerapps.io/oauth/callback
# Piloto WhatsApp: OAuth debe ser bloqueante y se usan cuentas Microsoft personales.
ACADEMIC_AGENT_REQUIRE_MICROSOFT_OAUTH=true
ACADEMIC_AGENT_EMAIL_VERIFICATION_MODE=disabled
ACADEMIC_AGENT_ALLOWED_EMAIL_DOMAINS=outlook.com,hotmail.com,live.com,msn.com

# ------------------------------------------------------------
# RAG (pipeline de recomendaciones)
# ------------------------------------------------------------
RAG_ENABLED=true
RAG_CORPUS_ROOT=knowledge_base/study_recommendations
RAG_CORPUS_NAME=study_recommendations
RAG_EMBEDDING_PROVIDER=azure_openai
RAG_EMBEDDING_MODEL=embeddings-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_TOP_K_VECTOR=8
RAG_TOP_K_LEXICAL=8
RAG_TOP_K_FINAL=5

# ------------------------------------------------------------
# Servidor HTTP
# ------------------------------------------------------------
PORT=8000
LOG_LEVEL=INFO
# URL publica base del despliegue. Si se omite, Lara intenta inferirla desde
# MICROSOFT_REDIRECT_URI para construir enlaces publicos como /legal/habeas-data.
# ACADEMIC_AGENT_PUBLIC_BASE_URL=https://TU_DOMINIO.azurecontainerapps.io
# URL externa opcional si la politica vive fuera del backend.
# LARA_HABEAS_DATA_URL=https://TU_DOMINIO/legal/habeas-data
# Activar solo en desarrollo local
RELOAD=false
