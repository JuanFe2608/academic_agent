# ============================================================
# Lara Academic Agent — Variables de entorno requeridas
# Copia este archivo como .env y rellena los valores
# ============================================================

# ------------------------------------------------------------
# Azure OpenAI (LLM + Embeddings)
# ------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_DEPLOYMENT_NAME_EMBEDDINGS=embeddings-3-small
OPENAI_API_VERSION=2024-02-01

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
PGHOST=
PGPORT=5432
PGDATABASE=academic_agent
PGUSER=
PGPASSWORD=
# Alternativa: URL completa (sobreescribe los campos anteriores)
# ACADEMIC_AGENT_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Checkpointer (por defecto usa la misma base de datos)
# LANGGRAPH_CHECKPOINTER_DATABASE_URL=

# ------------------------------------------------------------
# WhatsApp Cloud API
# ------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
# Token aleatorio que configuraste en Meta Developer Portal
WHATSAPP_VERIFY_TOKEN=

# ------------------------------------------------------------
# Microsoft Graph (OAuth + Outlook)
# ------------------------------------------------------------
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
# URL publica de tu despliegue + /oauth/callback
MICROSOFT_REDIRECT_URI=https://TU_DOMINIO.azurecontainerapps.io/oauth/callback

# ------------------------------------------------------------
# RAG (pipeline de recomendaciones)
# ------------------------------------------------------------
RAG_ENABLED=true
RAG_CORPUS_ROOT=knowledge_base/study_recommendations
RAG_CORPUS_NAME=study_recommendations
RAG_EMBEDDING_PROVIDER=azure_openai
RAG_EMBEDDING_MODEL=embeddings-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_TOP_K_VECTOR=8
RAG_TOP_K_LEXICAL=8
RAG_TOP_K_FINAL=5

# ------------------------------------------------------------
# Servidor HTTP
# ------------------------------------------------------------
PORT=8000
LOG_LEVEL=INFO
# Activar solo en desarrollo local
RELOAD=false
