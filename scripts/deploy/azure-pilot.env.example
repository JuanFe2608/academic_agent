# Copiar como scripts/deploy/azure-pilot.env y ajustar nombres.
# No guardar secretos aqui; los secretos salen del .env raiz del proyecto.

AZ_RESOURCE_GROUP=rg-lara-academic-agent-pilot
AZ_LOCATION=eastus

# Debe ser globalmente unico, solo minusculas y numeros.
AZ_ACR_NAME=laraacademicagentpilot

AZ_CONTAINERAPPS_ENV=cae-lara-academic-agent-pilot
AZ_CONTAINERAPP_NAME=ca-lara-academic-agent-pilot

AZ_IMAGE_NAME=academic-agent
AZ_IMAGE_TAG=pilot-001

# Puerto expuesto por Dockerfile/uvicorn.
AZ_TARGET_PORT=8000

# Limite intencional para piloto de 3 estudiantes.
AZ_MIN_REPLICAS=1
AZ_MAX_REPLICAS=1

# Solo para el primer despliegue, cuando aun no conoces el FQDN de Container Apps.
# Flujo:
# 1. poner true;
# 2. desplegar para obtener URL;
# 3. actualizar MICROSOFT_REDIRECT_URI=https://<fqdn>/oauth/callback en .env;
# 4. poner false;
# 5. volver a ejecutar preflight/deploy.
AZ_ALLOW_PLACEHOLDER_REDIRECT_FOR_FIRST_DEPLOY=false
